# Tell GitHub-linguist what NOT to count when classifying repo language.
# Without this, the iOS Swift native module dominates LOC and the repo
# shows up as "Swift" — misleading for an RN/TS library that consumers
# install from npm.
#
# linguist-vendored: file isn't this project's primary code (third-party or
#                    platform-bridge). Still shown in the file tree, but
#                    excluded from language stats.
# linguist-generated: file is build output, never edited by hand. Excluded
#                     AND collapsed in diffs.

# Native modules — they're the bridge, not the library's primary source.
ios/**            linguist-vendored
android/**        linguist-vendored

# Build output (TypeScript → JS, .d.ts, sourcemaps). Regenerated by `npm run build`.
build/**          linguist-generated

# Bundled license + attribution text from upstream model authors.
licenses/**       linguist-vendored

# Example app — useful reference but not part of the published library.
example/**        linguist-vendored

# Tools (Python venv, quantize scripts) are dev-time, not shipped.
tools/**          linguist-vendored

# Lockfiles & generated index docs.
*.lock            linguist-generated
package-lock.json linguist-generated
