{
  "expo": {
    "name": "TTSKit Demo",
    "slug": "ttskit-demo",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ttskit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ahkd.ttskitdemo",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.ahkd.ttskitdemo",
      "intentFilters": [
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-share-intent"
    ],
    "extra": {
      "eas": {
        "projectId": "560683cf-7ac7-486c-a1af-dd26a5282117"
      }
    },
    "owner": "adlmai"
  }
}