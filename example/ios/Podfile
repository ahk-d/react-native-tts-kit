require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

ENV['RCT_NEW_ARCH_ENABLED'] = '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] = podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']

platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'
install! 'cocoapods',
  :deterministic_uuids => false

prepare_react_native_project!

target 'SpeechKitDemo' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'npx',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => podfile_properties['apple.ccacheEnabled'] == 'true',
    )

    # This is necessary for Xcode 14, because it signs resource bundles by default
    # when building for devices.
    installer.target_installation_results.pod_target_installation_results
      .each do |pod_name, target_installation_result|
      target_installation_result.resource_bundle_targets.each do |resource_bundle_target|
        resource_bundle_target.build_configurations.each do |config|
          config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        end
      end
    end

    # Xcode 26 enforces stricter C++20 consteval rules that break the bundled
    # `fmt` library used transitively by React Native 0.79 (via glog/folly).
    # The defines must be written into the generated xcconfig files because
    # CocoaPods regenerates those after `target.build_configurations` runs.
    fmt_targets = ['fmt', 'glog', 'RCT-Folly']
    fmt_defines = 'FMT_USE_CONSTEVAL=0 FMT_USE_NONTYPE_TEMPLATE_ARGS=0'

    installer.pods_project.targets.each do |target|
      next unless fmt_targets.include?(target.name)
      target.build_configurations.each do |config|
        existing = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
        existing = [existing] unless existing.is_a?(Array)
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] =
          (existing + ['FMT_USE_CONSTEVAL=0', 'FMT_USE_NONTYPE_TEMPLATE_ARGS=0']).uniq
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
      end
    end

    # Patch generated xcconfig files directly — the in-memory build_settings
    # change above doesn't always survive CocoaPods' xcconfig regeneration.
    Dir.glob(File.join(installer.sandbox.target_support_files_root, '{fmt,glog,RCT-Folly}', '*.xcconfig')).each do |xcconfig|
      contents = File.read(xcconfig)
      next if contents.include?('FMT_USE_CONSTEVAL=0')
      patched = contents.lines.map do |line|
        if line.start_with?('GCC_PREPROCESSOR_DEFINITIONS')
          line.chomp + " #{fmt_defines}\n"
        else
          line
        end
      end
      unless patched.any? { |l| l.start_with?('GCC_PREPROCESSOR_DEFINITIONS') }
        patched << "GCC_PREPROCESSOR_DEFINITIONS = $(inherited) #{fmt_defines}\n"
      end
      File.write(xcconfig, patched.join)
    end

    # `fmt`'s base.h unconditionally redefines FMT_USE_CONSTEVAL based on
    # compiler detection — our -D flag is shadowed. Patch the header so the
    # macro respects any external definition.
    base_h = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(base_h)
      contents = File.read(base_h)
      sentinel = '// Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.'
      guard = "// Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.\n#if !defined(FMT_USE_CONSTEVAL)"
      unless contents.include?('#if !defined(FMT_USE_CONSTEVAL)')
        contents = contents.sub(sentinel, guard)
        contents = contents.sub("#if !defined(__cpp_lib_is_constant_evaluated)", "#if !defined(__cpp_lib_is_constant_evaluated)")
        # Close the new guard right before `#if FMT_USE_CONSTEVAL` block at end of detection.
        contents = contents.sub(
          "#endif\n#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval",
          "#endif\n#endif // !defined(FMT_USE_CONSTEVAL)\n#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval"
        )
        File.write(base_h, contents)
      end
    end
  end
end
